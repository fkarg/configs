#!/usr/bin/env bash
# Global git hook dispatcher. Installed by the terminal_dotfiles role and wired
# up via a global core.hooksPath in ~/.gitconfig, so it runs on EVERY repo on
# this machine, independent of which editor or AI coding agent made the change.
#
# Why a dispatcher: a global core.hooksPath makes git look ONLY in that one
# directory for hooks, ignoring each repo's own .git/hooks for every hook type
# (pre-commit, pre-push, ...). The standard hook names are symlinked to this
# script; it does its own work (commit-msg attribution blocking) and then
# delegates to the repo's own hook of the same name, so per-project hooks
# (pre-commit framework, etc.) are NOT silently disabled. We probe two
# locations, in order: the repo's default .git/hooks dir, and a conventional
# in-tree .githooks/ dir (which git never auto-discovers on its own). First
# executable match wins.
#
# A repo that sets its OWN core.hooksPath (husky -> .husky, or core.hooksPath
# = .githooks) overrides the global path entirely and never reaches this
# script — but a repo that merely commits a .githooks/ dir without changing
# config IS picked up here.
set -euo pipefail

hook="$(basename -- "$0")"
msg_file="${1:-}"

# --- commit-msg: enforce "no AI attribution in git history" ---
# HARD BLOCK the commit if it carries AI co-author trailers or "Generated
# with ..." footers. Legitimate human Co-authored-by trailers pass untouched
# (only claude/anthropic ones trip the wire). We reject rather than silently
# strip so the offending agent actually SEES it and stops doing it.
if [ "$hook" = "commit-msg" ] && [ -n "$msg_file" ] && [ -f "$msg_file" ]; then
  if grep -qiE '^[[:space:]]*Co-authored-by:.*(claude|anthropic)|Generated with \[?Claude Code|🤖 Generated with' "$msg_file"; then
    cat >&2 <<'EOF'

  ╔════════════════════════════════════════════════════════════════════╗
  ║  COMMIT REJECTED — AI ATTRIBUTION TRAILER DETECTED                  ║
  ╚════════════════════════════════════════════════════════════════════╝

  No fucking AI co-author trailers. No "Generated with Claude Code". No
  🤖 footers. Not now, not ever, in ANY repo on this machine.

  This is not a preference, it's a hard rule. Strip the Co-authored-by /
  Generated-with lines out of the commit message and try again.

  And FRIGGIN' REMEMBER IT this time so I don't have to keep blocking you.

EOF
    exit 1
  fi
fi

# --- delegate to the repo's own hook of the same name, if any ---
# Candidate dirs in priority order: the default per-repo hooks dir (.git/hooks,
# normally shadowed by our global core.hooksPath) and the conventional in-tree
# .githooks/ dir. First executable match wins.
git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"
toplevel="$(git rev-parse --show-toplevel 2>/dev/null || true)"
for dir in "${git_dir:+$git_dir/hooks}" "${toplevel:+$toplevel/.githooks}"; do
  [ -n "$dir" ] || continue
  local_hook="$dir/$hook"
  # Guard against recursing into ourselves (e.g. a repo whose core.hooksPath
  # points back here).
  if [ -x "$local_hook" ] && ! [ "$local_hook" -ef "$0" ]; then
    exec "$local_hook" "$@"
  fi
done

exit 0
