#!/usr/bin/env bash
# Resize the focused Hyprland window to a fraction of its monitor's logical
# (post-scaling) size.
#
# Usage:
#   hypr-resize <width_fraction> [<height_fraction>]   # fractional resize
#
# Examples:
#   hypr-resize 0.333          # focused window becomes 1/3 monitor-wide
#   hypr-resize 0.667          # 2/3 wide
#   hypr-resize 0.5 0.5        # half-and-half
#   hypr-resize 1 1            # fullscreen-ish (tile-respecting)
#
# Invoked from .desktop entries so it's discoverable in launchers
# (hyprlauncher, fuzzel, walker, rofi …).
#
# NOTE: an N-way "equalize all tiled windows" mode was removed. dwindle resizes
# act on its opaque binary split-tree, so for 3+ windows the outcome depends on
# the (unknowable-to-a-script) tree shape and reproducibly collapses a column
# instead of equalizing. Revisit equalization under the hy3 layout, where N-way
# splits are first-class — see nixos/shared/desktops/hyprland-session.nix.

set -u

mode=${1:-}
if [ -z "$mode" ]; then
  echo "usage: $0 <width_fraction> [<height_fraction>]" >&2
  exit 1
fi

mon=$(hyprctl monitors -j | jq '.[] | select(.focused)')
mw=$(jq -r '.width'  <<<"$mon")
mh=$(jq -r '.height' <<<"$mon")
scale=$(jq -r '.scale' <<<"$mon")

# Logical pixels = physical / scale; resize dispatchers expect logical.
lw=$(awk -v w="$mw" -v s="$scale" 'BEGIN{ printf "%d", w / s }')
lh=$(awk -v h="$mh" -v s="$scale" 'BEGIN{ printf "%d", h / s }')

ws_id=$(hyprctl activeworkspace -j | jq -r '.id')

# Fractional resize of the active window.
frac_w=$mode
frac_h=${2:-}

tw=$(awk -v w="$lw" -v f="$frac_w" 'BEGIN{ printf "%d", w * f }')
if [ -n "$frac_h" ]; then
  th=$(awk -v h="$lh" -v f="$frac_h" 'BEGIN{ printf "%d", h * f }')
else
  th=$(hyprctl activewindow -j | jq -r '.size[1]')
fi

# Lone-tile case: dwindle just snaps the tile back to fill the workspace, so
# float it first to make the resize visible. Multi-window splits work as is.
tiled_count=$(hyprctl clients -j \
  | jq --argjson w "$ws_id" '[.[] | select(.workspace.id == $w and .floating == false)] | length')
active_floating=$(hyprctl activewindow -j | jq -r '.floating')

if [ "$active_floating" = "false" ] && [ "$tiled_count" -le 1 ]; then
  hyprctl dispatch togglefloating >/dev/null
fi

hyprctl dispatch resizeactive exact "$tw" "$th" >/dev/null
