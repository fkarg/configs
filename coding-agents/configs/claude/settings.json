{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash(uv run python:*)",
      "Bash(uv run pyrefly:*)",
      "Bash(git log:*)",
      "Bash(git check-ignore:*)",
      "Bash(uv sync:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/agents-md-hook.sh",
            "statusMessage": "Loading AGENTS.md"
          }
        ]
      },
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/statusline-loc-reset.sh",
            "statusMessage": "Resetting LOC counter"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/stop-queue-hook.sh",
            "statusMessage": "Checking message queue"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "safety-net@safety-net-dev": true,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "feedbackSurveyRate": 0,
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "skipWorkflowUsageWarning": true,
  "editorMode": "normal",
  "verbose": true,
  "preferredNotifChannel": "kitty",
  "skipAutoPermissionPrompt": true
}
