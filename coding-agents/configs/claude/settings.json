{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "Bash(uv run python:*)",
      "Bash(uv run pyrefly:*)",
      "Bash(git log:*)",
      "Bash(git check-ignore:*)",
      "Bash(uv sync:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "safety-net@safety-net-dev": true,
    "pyright-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "feedbackSurveyRate": 0,
  "spinnerTipsEnabled": false,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "editorMode": "normal",
  "verbose": true,
  "preferredNotifChannel": "kitty",
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "dir=\"${CLAUDE_PROJECT_DIR:-$PWD}\"; root=$(git -C \"$dir\" rev-parse --show-toplevel 2>/dev/null) || root=\"$dir\"; if [ -f \"$root/AGENTS.md\" ] && [ ! -f \"$root/CLAUDE.md\" ] && [ ! -f \"$root/.claude/CLAUDE.md\" ]; then jq -Rs '{hookSpecificOutput:{hookEventName:\"SessionStart\",additionalContext:(\"Project AGENTS.md (auto-loaded because no CLAUDE.md is present):\\n\\n\" + .)}}' \"$root/AGENTS.md\"; fi 2>/dev/null || true",
            "statusMessage": "Loading AGENTS.md"
          }
        ]
      }
    ]
  }
}
