#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  codex-account status
  codex-account list
  codex-account save <personal|business|name>
  codex-account use <personal|business|name>
  codex-account login <personal|business|name> [--device-auth]

Profiles are stored in ~/.codex/account-auth/<name>/auth.json.

Typical setup:
  codex-account save personal
  codex-account login business
  codex-account use personal
  codex-account use business

After switching accounts, start a new Codex CLI / IDE session so the process
loads the new credentials.
EOF
}

die() {
  printf 'codex-account: %s\n' "$*" >&2
  exit 1
}

codex_home="${CODEX_HOME:-$HOME/.codex}"
auth_file="$codex_home/auth.json"
store_dir="$codex_home/account-auth"
active_file="$store_dir/active"

ensure_store() {
  mkdir -p "$store_dir"
  chmod 700 "$store_dir"
}

validate_profile() {
  local profile="$1"
  case "$profile" in
    ''|.*|*/*|*' '*)
      die "invalid profile name '$profile'"
      ;;
  esac
}

profile_auth_file() {
  local profile="$1"
  printf '%s/%s/auth.json' "$store_dir" "$profile"
}

save_current_as() {
  local profile="$1"
  validate_profile "$profile"
  test -f "$auth_file" || die "no active auth file at $auth_file; run 'codex login' first"

  local profile_dir="$store_dir/$profile"
  mkdir -p "$profile_dir"
  chmod 700 "$profile_dir"
  cp "$auth_file" "$profile_dir/auth.json"
  chmod 600 "$profile_dir/auth.json"
}

save_active_profile_if_known() {
  test -f "$active_file" || return 0
  test -f "$auth_file" || return 0

  local active
  active="$(cat "$active_file")"
  test -n "$active" || return 0
  save_current_as "$active"
}

require_known_active_or_no_auth() {
  test ! -f "$auth_file" && return 0
  test -f "$active_file" && return 0

  die "active Codex credentials are not assigned to a profile; run 'codex-account save personal' first"
}

cmd="${1:-}"
case "$cmd" in
  status)
    ensure_store
    if test -f "$active_file"; then
      printf 'active profile: %s\n' "$(cat "$active_file")"
    else
      printf 'active profile: unknown\n'
    fi

    if test -f "$auth_file"; then
      printf 'auth file: %s\n' "$auth_file"
    else
      printf 'auth file: missing\n'
    fi

    if command -v codex >/dev/null 2>&1; then
      codex login status || true
    fi
    ;;

  list)
    ensure_store
    found=0
    seen_accounts=''
    for dir in "$store_dir"/*; do
      test -d "$dir" || continue
      test -f "$dir/auth.json" || continue
      found=1
      profile="$(basename "$dir")"

      if test -f "$active_file" && test "$(cat "$active_file" 2>/dev/null)" = "$profile"; then
        active_marker="*"
      else
        active_marker=" "
      fi

      account_id="$(jq -r '.tokens.account_id // empty' "$dir/auth.json" 2>/dev/null || true)"
      duplicate_profile=""
      if test -n "$account_id" && test "$account_id" != "null"; then
        duplicate_profile="$(printf '%s' "$seen_accounts" | awk -F '\t' -v id="$account_id" '$1 == id { print $2; exit }')"
        if test -z "$duplicate_profile"; then
          printf -v seen_accounts '%s%s\t%s\n' "$seen_accounts" "$account_id" "$profile"
        fi
      fi

      access_token="$(jq -r '.tokens.access_token // empty' "$dir/auth.json" 2>/dev/null)"
      if test -n "$access_token" && test "$access_token" != "null"; then
        usage_json="$(curl -sf -H "Authorization: Bearer $access_token" -H "User-Agent: codex-cli" https://chatgpt.com/backend-api/wham/usage 2>/dev/null || true)"
        if test -n "$usage_json"; then
          plan_type="$(printf '%s' "$usage_json" | jq -r '.plan_type // "unknown"')"

          primary_used="$(printf '%s' "$usage_json" | jq -r '.rate_limit.primary_window.used_percent // 0')"
          primary_window_sec="$(printf '%s' "$usage_json" | jq -r '.rate_limit.primary_window.limit_window_seconds // 0')"
          primary_reset_sec="$(printf '%s' "$usage_json" | jq -r '.rate_limit.primary_window.reset_after_seconds // 0')"
          primary_reset_at="$(printf '%s' "$usage_json" | jq -r '.rate_limit.primary_window.reset_at // 0')"

          secondary_used="$(printf '%s' "$usage_json" | jq -r '.rate_limit.secondary_window.used_percent // 0')"
          secondary_window_sec="$(printf '%s' "$usage_json" | jq -r '.rate_limit.secondary_window.limit_window_seconds // 0')"
          secondary_reset_sec="$(printf '%s' "$usage_json" | jq -r '.rate_limit.secondary_window.reset_after_seconds // 0')"
          secondary_reset_at="$(printf '%s' "$usage_json" | jq -r '.rate_limit.secondary_window.reset_at // 0')"

          primary_window_h=$((primary_window_sec / 3600))
          primary_reset_h=$((primary_reset_sec / 3600))
          primary_reset_m=$(((primary_reset_sec % 3600) / 60))

          secondary_window_d=$((secondary_window_sec / 86400))
          secondary_reset_d=$((secondary_reset_sec / 86400))
          secondary_reset_h=$(((secondary_reset_sec % 86400) / 3600))

          printf '%s%-15s %s\n' "$active_marker" "$profile" "$plan_type"
          printf '  session:  %3d%% used (%dh window)  reset in %dh%dm\n' "$primary_used" "$primary_window_h" "$primary_reset_h" "$primary_reset_m"
          printf '  weekly:   %3d%% used (%dd window)  reset in %dd%dh\n' "$secondary_used" "$secondary_window_d" "$secondary_reset_d" "$secondary_reset_h"
        else
          printf '%s%-15s (rate limit fetch failed)\n' "$active_marker" "$profile"
        fi
      else
        printf '%s%-15s (no access token)\n' "$active_marker" "$profile"
      fi
      if test -n "$duplicate_profile"; then
        printf "  warning: same Codex account as profile '%s'\n" "$duplicate_profile"
      fi
    done
    test "$found" -eq 1 || printf 'no saved profiles\n'
    ;;

  save)
    profile="${2:-}"
    test -n "$profile" || die "missing profile name"
    ensure_store
    save_current_as "$profile"
    printf '%s\n' "$profile" > "$active_file"
    chmod 600 "$active_file"
    printf 'saved active Codex credentials as profile: %s\n' "$profile"
    ;;

  use)
    profile="${2:-}"
    test -n "$profile" || die "missing profile name"
    validate_profile "$profile"
    ensure_store

    target="$(profile_auth_file "$profile")"
    test -f "$target" || die "unknown profile '$profile'; run 'codex-account login $profile' or 'codex-account save $profile'"

    require_known_active_or_no_auth
    save_active_profile_if_known
    cp "$target" "$auth_file"
    chmod 600 "$auth_file"
    printf '%s\n' "$profile" > "$active_file"
    chmod 600 "$active_file"
    printf 'switched Codex credentials to profile: %s\n' "$profile"
    printf 'start a new Codex CLI / IDE session before relying on the new account\n'
    ;;

  login)
    profile="${2:-}"
    shift 2 || true
    test -n "$profile" || die "missing profile name"
    validate_profile "$profile"
    ensure_store

    require_known_active_or_no_auth
    save_active_profile_if_known
    rm -f "$auth_file"
    codex login "$@"
    save_current_as "$profile"
    printf '%s\n' "$profile" > "$active_file"
    chmod 600 "$active_file"
    printf 'logged in and saved Codex profile: %s\n' "$profile"
    ;;

  -h|--help|help|'')
    usage
    ;;

  *)
    usage >&2
    exit 2
    ;;
esac
